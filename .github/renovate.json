{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "dependencyDashboard": true,
  "platformAutomerge": true,
  "reviewers": [
    "SjnExe"
  ],
  "assignees": [
    "SjnExe"
  ],
  "packageRules": [
    {
      "groupName": "all dependencies",
      "automerge": true,
      "automergeType": "branch",
      "matchPackageNames": [
        "*"
      ]
    }
  ]
}
