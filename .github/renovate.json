{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":pinDigestsDisabled"
  ],
  "pin": { "enabled": false },
  "pinDigests": false,
  "lockFileMaintenance": { "enabled": false },
  "rangeStrategy": "replace",
  "dependencyDashboard": true,
  "packageRules": [
    {
      "matchPackageNames": ["*"],
      "groupName": "all dependencies",
      "automerge": true,
      "automergeType": "branch"
    }
  ]
}
